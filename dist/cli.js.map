export default "{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"$id\": \"https://kata.dev/schemas/review-finding.schema.json\",\n  \"title\": \"Kata Review Finding\",\n  \"type\": \"object\",\n  \"required\": [\"id\", \"taskId\", \"severity\", \"message\"],\n  \"additionalProperties\": false,\n  \"properties\": {\n    \"id\": { \"type\": \"string\", \"minLength\": 1 },\n    \"taskId\": { \"type\": \"string\", \"minLength\": 1 },\n    \"acceptanceId\": { \"type\": \"string\", \"pattern\": \"^AC-[0-9]+$\" },\n    \"severity\": { \"type\": \"string\", \"enum\": [\"blocking\", \"major\", \"minor\", \"note\"] },\n    \"message\": { \"type\": \"string\", \"minLength\": 1 },\n    \"path\": { \"type\": \"string\", \"minLength\": 1 }\n  }\n}\n";