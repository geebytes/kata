{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kata.dev/schemas/wiki-record.schema.json",
  "title": "Kata Governed Wiki Record",
  "type": "object",
  "required": [
    "id",
    "statement",
    "scope",
    "kind",
    "sourceRefs",
    "sourceHashes",
    "validationTaskId",
    "evidenceIds",
    "status",
    "lastVerifiedAt",
    "createdAt",
    "updatedAt"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "statement": { "type": "string", "minLength": 1 },
    "scope": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "kind": { "type": "string", "minLength": 1 },
    "sourceRefs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "sourceHashes": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
    },
    "validationTaskId": { "type": "string", "minLength": 1 },
    "evidenceIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "status": { "type": "string", "enum": ["candidate", "verified", "stale", "rejected"] },
    "lastVerifiedAt": { "type": "string" },
    "createdAt": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 },
    "approvalEvent": {
      "type": "object",
      "required": ["approvedBy", "role", "approvedAt"],
      "additionalProperties": false,
      "properties": {
        "approvedBy": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "approvedAt": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      }
    },
    "rejectionEvent": {
      "type": "object",
      "required": ["rejectedBy", "role", "rejectedAt", "reason"],
      "additionalProperties": false,
      "properties": {
        "rejectedBy": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "rejectedAt": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}
