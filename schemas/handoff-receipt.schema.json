{
  "type": "object",
  "required": ["protocolVersion", "taskId", "handoffId", "platform", "role", "packetSha256", "acknowledgedAt"],
  "properties": {
    "protocolVersion": { "type": "integer", "minimum": 1 },
    "taskId": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$" },
    "handoffId": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$" },
    "platform": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$" },
    "role": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$" },
    "packetSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "acknowledgedAt": { "type": "string", "minLength": 1 }
  }
}
