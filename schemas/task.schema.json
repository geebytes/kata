{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kata.dev/schemas/task.schema.json",
  "title": "Kata Task",
  "type": "object",
  "required": ["id", "title", "phase", "acceptance", "createdAt", "updatedAt"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$" },
    "title": { "type": "string", "minLength": 1 },
    "phase": {
      "type": "string",
      "enum": ["intake", "plan", "implement", "hardVerify", "review", "judge", "distill", "archive"]
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["statement"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^AC-[0-9]+$" },
          "statement": { "type": "string", "minLength": 1 }
        }
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "targetTaskId", "createdAt"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["superseded_by", "covered_by", "duplicate_of", "merged_into", "parent_of", "spawned_from", "related_to"]
          },
          "targetTaskId": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$" },
          "reason": { "type": "string", "minLength": 1 },
          "createdAt": { "type": "string", "minLength": 1 },
          "createdBy": { "type": "string", "minLength": 1 }
        }
      }
    },
    "createdAt": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 },
    "workflowProfile": {
      "type": "object",
      "required": ["version", "isolationMode", "developmentMode", "reviewMode", "comet"],
      "properties": {
        "version": { "const": 1 },
        "isolationMode": { "enum": ["current_worktree", "isolated_worktree", "git_flow", "user_decides"] },
        "developmentMode": { "enum": ["tdd", "standard"] },
        "reviewMode": { "enum": ["std", "strict", "security"] },
        "gitFlow": {
          "type": "object",
          "required": ["strategy", "branch", "baseBranch", "status"],
          "properties": {
            "strategy": { "enum": ["git-flow", "manual"] },
            "branch": { "type": "string" },
            "baseBranch": { "type": "string" },
            "status": { "enum": ["active", "pending_confirmation", "failed"] },
            "installation": {
              "type": "object",
              "required": ["status"],
              "properties": {
                "status": { "enum": ["installed", "failed", "unsupported"] },
                "command": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "manualCommand": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "comet": {
          "type": "object",
          "required": ["projectInit", "openStatus"],
          "properties": {
            "projectInit": { "enum": ["not_requested", "initialized", "skipped", "failed"] },
            "openStatus": { "enum": ["required", "acknowledged"] }
          },
          "additionalProperties": false
        },
        "strictClosure": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "ownedPaths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "acceptanceMatrix": {
      "type": "object",
      "required": ["version", "rows"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["acceptanceId", "implementationPaths", "testPaths", "evidence", "verificationLevel"],
            "additionalProperties": false,
            "properties": {
              "acceptanceId": { "type": "string", "pattern": "^AC-[0-9]+$" },
              "designRefs": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "implementationPaths": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "testPaths": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "evidence": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["kind", "command"],
                  "additionalProperties": false,
                  "properties": {
                    "kind": {
                      "type": "string",
                      "enum": ["test", "lint", "typecheck", "integration", "entrypoint"]
                    },
                    "command": { "type": "string", "minLength": 1 },
                    "testSelector": { "type": "string", "minLength": 1 }
                  }
                }
              },
              "verificationLevel": {
                "type": "string",
                "enum": ["unit", "integration", "entrypoint"]
              }
            }
          }
        }
      }
    }
  }
}
