{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kata.dev/schemas/evidence.schema.json",
  "title": "Kata Evidence Envelope",
  "type": "object",
  "required": ["id", "taskId", "kind", "command", "exitCode", "startedAt", "finishedAt", "diffHash"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.-]+$" },
    "kind": {
      "type": "string",
      "enum": ["lint", "typecheck", "test", "ci", "review", "judge", "security"]
    },
    "command": { "type": "string", "minLength": 1 },
    "environment": { "type": "string" },
    "exitCode": { "type": "integer", "minimum": 0 },
    "startedAt": { "type": "string", "minLength": 1 },
    "finishedAt": { "type": "string", "minLength": 1 },
    "diffHash": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
    "revisionId": { "type": "string", "minLength": 1 },
    "scope": {
      "type": "object",
      "required": ["paths", "hash"],
      "additionalProperties": false,
      "properties": {
        "paths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "hash": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
      }
    },
    "log": { "type": "string" }
  }
}
