{
    "$schema": "https://opencode.ai/config.json",
    "provider": {
        "myprovider": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "litellm",
            "options": {
                "baseURL": "http://127.0.0.1:4000/v1",
                "apiKey": "sk-P2-ES1oUH93HI9cqcvpvkA"
            },
            "models": {
                "deepseek-v4-flash-free": {
                    "name": "DeepSeek V4 Flash"
                },
                "deepseek-v4-pro": {
                    "name": "DeepSeek V4 Pro"
                },
                "glm-5.2": {
                    "name": "GLM 5.2"
                },
                "glm-4.7": {
                    "name": "GLM 4.7"
                },
                "grok-4.5-medium": {
                    "name": "GROK 4.5"
                }
            }
        }
    },
    "mcp": {
        "codegraph": {
            "type": "local",
            "command": [
                "codegraph",
                "serve",
                "--mcp"
            ],
            "enabled": true
        },
        "claude-context": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@zilliz/claude-context-mcp@latest"
            ],
            "enabled": true,
            "timeout": 20000,
            "environment": {
                "EMBEDDING_PROVIDER": "OpenAI",
                "EMBEDDING_MODEL": "qwen3-embedding-gguf",
                "OPENAI_BASE_URL": "http://localhost:4000/v1",
                "OPENAI_API_KEY": "sk-dkuPsTJwDsPsOQuZB1X_cw",
                "MILVUS_ADDRESS": "http://127.0.0.1:19530",
                "HYBRID_MODE": "true",
                "EMBEDDING_BATCH_SIZE": "32"
            }
        }
    }
}